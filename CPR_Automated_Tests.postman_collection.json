{
	"info": {
		"_postman_id": "cpr-trainer-full-test-collection",
		"name": "CPR-Trainer Full System Tests",
		"description": "Comprehensive tests for CPR Monitoring System including negative cases and system health.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. System Health Check",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Server is Online\", function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().server).to.eql(\"online\");",
							"});",
							"pm.test(\"Serial Port status is present\", function () {",
							"    pm.expect(pm.response.json()).to.have.property('serialConnected');",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:3001/api/status",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "3001",
					"path": [
						"api",
						"status"
					]
				}
			},
			"response": []
		},
		{
			"name": "1. Login (Success)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Login successful\", function () {",
							"    pm.response.to.have.status(200);",
							"    pm.expect(pm.response.json().message).to.contains(\"successful\");",
							"});"
