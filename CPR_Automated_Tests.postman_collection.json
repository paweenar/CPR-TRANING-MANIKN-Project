					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"Session started successfully\", function () {",
							"    pm.response.to.have.status(200);",
							"    var jsonData = pm.response.json();",
							"    pm.expect(jsonData.session).to.have.property('id');",
							"    pm.collectionVariables.set(\"active_session_id\", jsonData.session.id);",
							"});"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"trainee_name\": \"Full Test Trainee\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "http://localhost:3001/api/sessions/start",
					"protocol": "http",
